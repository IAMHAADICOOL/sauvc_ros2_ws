<?xml version='1.0' encoding='UTF-8'?>
<!-- PlotJuggler layout for the localization comparison.
     Load: PlotJuggler -> File -> Layout -> Load, pick this file.
     Then start the ROS2 streaming source (ROS2 Topic Subscriber) and select the
     /eval/* topics. Three plots stack vertically: X, Y, and depth (Z), each overlaying
     ground_truth + flow + ekf + pressure + gtsam so you can watch drift accumulate. -->
<root>
  <tabbed_widget name="Main Window" parent="main_window">
    <Tab tab_name="localization comparison" containers="1">
      <Container>
        <DockSplitter orientation="-" count="3" sizes="0.34;0.33;0.33">
          <DockArea name="X  (forward, compare-frame)">
            <plot mode="TimeSeries" style="Lines">
              <range right="1" left="0" top="1" bottom="0"/>
              <limitY/>
              <curve name="/eval/ground_truth/pose/pose/position/x" color="#000000"/>
              <curve name="/eval/flow/pose/pose/position/x" color="#1f77b4"/>
              <curve name="/eval/ekf/pose/pose/position/x" color="#2ca02c"/>
              <curve name="/eval/gtsam/pose/pose/position/x" color="#d62728"/>
            </plot>
          </DockArea>
          <DockArea name="Y  (left, compare-frame)">
            <plot mode="TimeSeries" style="Lines">
              <range right="1" left="0" top="1" bottom="0"/>
              <limitY/>
              <curve name="/eval/ground_truth/pose/pose/position/y" color="#000000"/>
              <curve name="/eval/flow/pose/pose/position/y" color="#1f77b4"/>
              <curve name="/eval/ekf/pose/pose/position/y" color="#2ca02c"/>
              <curve name="/eval/gtsam/pose/pose/position/y" color="#d62728"/>
            </plot>
          </DockArea>
          <DockArea name="Depth  (Z, compare-frame)">
            <plot mode="TimeSeries" style="Lines">
              <range right="1" left="0" top="1" bottom="0"/>
              <limitY/>
              <curve name="/eval/ground_truth/pose/pose/position/z" color="#000000"/>
              <curve name="/eval/flow/pose/pose/position/z" color="#1f77b4"/>
              <curve name="/eval/ekf/pose/pose/position/z" color="#2ca02c"/>
              <curve name="/eval/pressure/pose/pose/position/z" color="#ff7f0e"/>
              <curve name="/eval/gtsam/pose/pose/position/z" color="#d62728"/>
            </plot>
          </DockArea>
        </DockSplitter>
      </Container>
    </Tab>
  </tabbed_widget>
  <!-- legend: black=ground truth  blue=flow+altitude  green=ekf  orange=pressure  red=gtsam -->
</root>
